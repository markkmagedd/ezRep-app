// ══════════════════════════════════════════════════════════════════════════════
//  ezRep — Prisma Schema
//
//  This file defines all database tables. Apply to Supabase by running:
//    npx prisma db push
//
//  Note: RLS policies, auth triggers, and realtime publications are in
//        supabase/rls.sql — run that once in the Supabase SQL editor.
// ══════════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Use the pooler URL for the app (SESSION mode, port 5432)
  url       = env("DATABASE_URL")
  // Use the direct URL for schema pushes / migrations
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
//  PROFILES
//  id mirrors auth.users — Supabase creates rows via trigger (see rls.sql)
// ─────────────────────────────────────────────────────────────────────────────
model Profile {
  id            String   @id @db.Uuid
  username      String   @unique
  displayName   String?  @map("display_name")
  avatarUrl     String?  @map("avatar_url")
  totalVolumeKg Decimal  @default(0) @map("total_volume_kg") @db.Decimal(12, 2)
  totalSessions Int      @default(0) @map("total_sessions")
  email         String?
  createdAt     DateTime @default(now()) @map("created_at")

  workouts              Workout[]
  hostedSessions        Session[]            @relation("HostedSessions")
  sessionParticipations SessionParticipant[]
  sessionSets           SessionSet[]
  routines              Routine[]

  @@map("profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
//  WORKOUTS  (solo sessions)
// ─────────────────────────────────────────────────────────────────────────────
model Workout {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  name          String    @default("Workout")
  startedAt     DateTime  @default(now()) @map("started_at")
  endedAt       DateTime? @map("ended_at")
  totalVolumeKg Decimal   @default(0) @map("total_volume_kg") @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  routineId     String?   @map("routine_id") @db.Uuid
  routineDayId  String?   @map("routine_day_id") @db.Uuid

  user       Profile           @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises  WorkoutExercise[]
  routine    Routine?          @relation(fields: [routineId], references: [id], onDelete: SetNull)
  routineDay RoutineDay?       @relation(fields: [routineDayId], references: [id], onDelete: SetNull)

  @@map("workouts")
}

model WorkoutExercise {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workoutId    String @map("workout_id") @db.Uuid
  exerciseId   String @map("exercise_id")
  exerciseName String @map("exercise_name")
  orderIndex   Int    @default(0) @map("order_index")

  workout Workout      @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  sets    WorkoutSet[]

  @@map("workout_exercises")
}

model WorkoutSet {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workoutExerciseId String   @map("workout_exercise_id") @db.Uuid
  setIndex          Int      @map("set_index")
  reps              Int      @default(0)
  weightKg          Decimal  @default(0) @map("weight_kg") @db.Decimal(8, 2)
  isWarmup          Boolean  @default(false) @map("is_warmup")
  completed         Boolean  @default(false)
  loggedAt          DateTime @default(now()) @map("logged_at")

  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@map("workout_sets")
}

// ─────────────────────────────────────────────────────────────────────────────
//  SESSIONS  (real-time group workouts)
// ─────────────────────────────────────────────────────────────────────────────
model Session {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                 String    @unique @db.Char(6)
  hostId               String    @map("host_id") @db.Uuid
  status               String    @default("lobby")
  currentExerciseIndex Int       @default(0) @map("current_exercise_index")
  createdAt            DateTime  @default(now()) @map("created_at")
  startedAt            DateTime? @map("started_at")
  endedAt              DateTime? @map("ended_at")

  host         Profile              @relation("HostedSessions", fields: [hostId], references: [id])
  participants SessionParticipant[]
  exercises    SessionExercise[]
  sets         SessionSet[]

  @@map("sessions")
}

model SessionParticipant {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId  String    @map("session_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  colorIndex Int       @default(0) @map("color_index")
  isReady    Boolean   @default(false) @map("is_ready")
  joinedAt   DateTime  @default(now()) @map("joined_at")
  leftAt     DateTime? @map("left_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    Profile @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@map("session_participants")
}

model SessionExercise {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId    String @map("session_id") @db.Uuid
  exerciseId   String @map("exercise_id")
  exerciseName String @map("exercise_name")
  orderIndex   Int    @default(0) @map("order_index")
  targetSets   Int    @default(3) @map("target_sets")
  targetReps   Int    @default(10) @map("target_reps")

  session Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sets    SessionSet[]

  @@map("session_exercises")
}

model SessionSet {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionExerciseId String   @map("session_exercise_id") @db.Uuid
  sessionId         String   @map("session_id") @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  setIndex          Int      @map("set_index")
  reps              Int      @default(0)
  weightKg          Decimal  @default(0) @map("weight_kg") @db.Decimal(8, 2)
  loggedAt          DateTime @default(now()) @map("logged_at")

  sessionExercise SessionExercise @relation(fields: [sessionExerciseId], references: [id], onDelete: Cascade)
  session         Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user            Profile         @relation(fields: [userId], references: [id])

  @@map("session_sets")
}

// ─────────────────────────────────────────────────────────────────────────────
//  ROUTINES  (structured training programs)
//  Hierarchy: Routine → RoutineDay → RoutineDayExercise
// ─────────────────────────────────────────────────────────────────────────────
model Routine {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  name            String
  isActive        Boolean  @default(false) @map("is_active")
  currentDayIndex Int      @default(0) @map("current_day_index")
  createdAt       DateTime @default(now()) @map("created_at")

  user     Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  days     RoutineDay[]
  workouts Workout[]

  @@map("routines")
}

model RoutineDay {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  routineId String @map("routine_id") @db.Uuid
  dayNumber Int    @map("day_number")
  name      String

  routine   Routine              @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercises RoutineDayExercise[]
  workouts  Workout[]

  @@unique([routineId, dayNumber])
  @@map("routine_days")
}

model RoutineDayExercise {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  routineDayId   String   @map("routine_day_id") @db.Uuid
  exerciseId     String   @map("exercise_id")
  exerciseName   String   @map("exercise_name")
  orderIndex     Int      @default(0) @map("order_index")
  targetSets     Int      @default(3) @map("target_sets")
  targetReps     Int      @default(10) @map("target_reps")
  targetWeightKg Decimal? @map("target_weight_kg") @db.Decimal(8, 2)

  routineDay RoutineDay @relation(fields: [routineDayId], references: [id], onDelete: Cascade)

  @@map("routine_day_exercises")
}
